# Public URL the service lives at (used to build OAuth callback + claude mcp add snippet)
PUBLIC_URL=https://sheets-mcp.digiboffins.com

# Express bind
PORT=5020

# MongoDB Atlas (free M0 is plenty)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/sheets-mcp?retryWrites=true&w=majority

# Google Cloud OAuth (Web app type, NOT Desktop)
# Authorized redirect URI MUST be: ${PUBLIC_URL}/auth/google/callback
GOOGLE_CLIENT_ID=your-client.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# AES-256-GCM key for encrypting refresh tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=64-hex-chars-here-do-not-commit
